# Copy this to .env (never commit .env)
# Replace placeholders with real values locally only

# GitHub — used by import scripts
GITHUB_TOKEN=ghp_your_token_here

# Optional: model API keys for experiment notebooks
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here
MOONSHOT_API_KEY=your_key_here

# Secret scanner threshold (low | medium | high)
SECRET_SCAN_THRESHOLD=low
